generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String                  @id @default(cuid())
  name               String?
  email              String                  @unique
  password           String
  passwordEncrypted  String?                 @map("password_encrypted")
  roleId             String
  isActive           Boolean                 @default(true) @map("is_active")
  approvalStatus     UserApprovalStatus      @default(ACTIVE) @map("approval_status")
  sessionVersion     Int                     @default(0) @map("session_version")
  dateOfJoining      String?                 @map("date_of_joining")
  createdById        String?                 @map("created_by_id")
  role               Role                    @relation(fields: [roleId], references: [id], onDelete: Restrict)
  createdBy          User?                   @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers       User[]                  @relation("UserCreatedBy")
  auditSubmissions   AuditSubmission[]
  templatePreference UserTemplatePreference?
  provisioningRequests UserProvisioningRequest[] @relation("ProvisioningRequestedBy")
  provisioningReviews  UserProvisioningRequest[] @relation("ProvisioningReviewedBy")
  approvedFromRequest  UserProvisioningRequest?  @relation("ApprovedUser")
  agentAssignments     AgentAssignment[]       @relation("AgentAssignments")
  assignedAgents       AgentAssignment[]       @relation("AssignedAgentsTo")
  assignmentsMade      AgentAssignment[]       @relation("AgentAssignedByQM")
  securityAuditTargets SecurityAuditLog[]      @relation("SecurityAuditTarget")
  securityAuditActions SecurityAuditLog[]      @relation("SecurityAuditActor")
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([createdById])
  @@index([isActive])
  @@index([approvalStatus])
  @@index([roleId])
  @@index([createdAt])
  @@index([roleId, isActive])
}

enum UserApprovalStatus {
  ACTIVE
  PENDING_APPROVAL
  REJECTED
}

model AgentAssignment {
  id           String   @id @default(cuid())
  agentId      String   @map("agent_id")
  assignedToId String   @map("assigned_to_id")
  assignedById String   @map("assigned_by_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  agent      User @relation("AgentAssignments", fields: [agentId], references: [id], onDelete: Cascade)
  assignedTo User @relation("AssignedAgentsTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedBy User @relation("AgentAssignedByQM", fields: [assignedById], references: [id], onDelete: Restrict)

  @@unique([agentId, assignedToId])
  @@index([assignedToId])
  @@index([assignedById])
  @@index([agentId])
  @@map("agent_assignments")
}

model SecurityAuditLog {
  id           String   @id @default(cuid())
  action       String
  actorUserId  String   @map("actor_user_id")
  targetUserId String?  @map("target_user_id")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  actor  User  @relation("SecurityAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  target User? @relation("SecurityAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([actorUserId])
  @@index([targetUserId])
  @@map("security_audit_logs")
}

enum UserProvisioningStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserProvisioningRequest {
  id             String                   @id @default(cuid())
  name           String
  email          String
  passwordHash   String                   @map("password_hash")
  passwordEncrypted String?               @map("password_encrypted")
  dateOfJoining  String?                  @map("date_of_joining")
  targetRoleSlug String                   @map("target_role_slug")
  status         UserProvisioningStatus   @default(PENDING)
  requestedById  String                   @map("requested_by_id")
  requestedBy    User                     @relation("ProvisioningRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  reviewedById   String?                  @map("reviewed_by_id")
  reviewedBy     User?                    @relation("ProvisioningReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote     String?                  @map("review_note")
  reviewedAt     DateTime?                @map("reviewed_at")
  createdUserId  String?                  @unique @map("created_user_id")
  createdUser    User?                    @relation("ApprovedUser", fields: [createdUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  @@index([status, targetRoleSlug])
  @@index([requestedById])
  @@index([email])
  @@map("user_provisioning_requests")
}

model Role {
  id          String             @id @default(cuid())
  name        String             @unique
  slug        String             @unique
  description String?
  isSystem    Boolean            @default(false)
  users       User[]
  scopes      RoleScope[]
  templates   RoleFormTemplate[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model Scope {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String?
  roles       RoleScope[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model RoleScope {
  roleId     String
  scopeId    String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  scope      Scope    @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@id([roleId, scopeId])
}

model FormTemplate {
  id          String   @id
  name        String
  type        String
  lob         String   @default("")
  description String   @default("")
  isDefault   Boolean  @default(false) @map("is_default")
  sections    Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  preferences UserTemplatePreference[]
  submissions AuditSubmission[]
  roles       RoleFormTemplate[]

  @@map("form_templates")
}

model RoleFormTemplate {
  roleId     String       @map("role_id")
  templateId String       @map("template_id")
  role       Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  template   FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  assignedAt DateTime     @default(now()) @map("assigned_at")

  @@id([roleId, templateId])
  @@map("role_form_templates")
}

model UserTemplatePreference {
  userId           String       @id @map("user_id")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeTemplateId String       @map("active_template_id")
  activeTemplate   FormTemplate @relation(fields: [activeTemplateId], references: [id], onDelete: Restrict)
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@map("user_template_preferences")
}

model InteractionConfig {
  id            String   @id @default("default")
  config        Json
  configVersion Int      @default(0) @map("config_version")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("interaction_configs")
}

model Agent {
  id            String   @id @default(cuid())
  name          String   @unique
  nameKey       String   @unique @map("name_key")
  dateOfJoining String?  @map("date_of_joining")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("agents")
}

model SystemMeta {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_meta")
}

model AuditSubmission {
  id             String        @id @default(cuid())
  auditCode      String        @unique
  submissionKey  String?       @unique @map("submission_key")
  templateId     String?       @map("template_id")
  template       FormTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  submittedById  String
  submittedBy    User          @relation(fields: [submittedById], references: [id], onDelete: Restrict)
  agent          String
  supervisor     String?
  auditor        String?
  type           String
  businessType   String
  callDate       String
  auditDate      String
  lob            String
  sublob         String?
  reason         String?
  mobile         String?
  referenceUrl   String?  @map("reference_url")
  response       String?
  qualityPct     Int
  finalPct       Int
  grade          String
  hasFatal       Boolean  @default(false)
  fatalList      Json     @default("[]")
  feedbackStatus   String   @default("Pending")
  feedbackSecurity String   @default("NA")
  feedbackDate     String?
  feedbackStatusAt String?  @map("feedback_status_at")
  agentFeedback    String   @default("")
  supervisorRemarks String  @default("") @map("supervisor_remarks")
  totalScored    Float
  totalMax       Float
  scores         Json
  catScores      Json
  rows           Json
  record         Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agent])
  @@index([lob])
  @@index([grade])
  @@index([createdAt])
  @@index([submittedById])
  @@index([templateId])
  @@index([auditor])
  @@index([auditDate])
  @@index([feedbackStatus])
  @@index([submittedById, auditDate])
  @@index([templateId, auditDate])
  @@index([id, createdAt])
}
