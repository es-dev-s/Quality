# Copy to .env on your Windows Server (same folder as package.json).
# Use the exact URL users type in the browser — IP or hostname, with port.

DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

AUTH_SECRET="generate-a-long-random-string-at-least-32-chars"
AUTH_TRUST_HOST="true"
AUTH_SECURE_COOKIES="false"

# How users reach the app (must match the browser address bar)
APP_URL="http://10.80.80.221:4782"

# Optional: extra hostnames if users open the site different ways
ALLOWED_ORIGINS="10.80.80.221:4782"

PORT="4782"
HOSTNAME="0.0.0.0"

SUPERADMIN_EMAIL="admin@example.com"
SUPERADMIN_PASSWORD="change-me"
SUPERADMIN_NAME="Super Admin"

DATABASE_POOL_MAX="5"
