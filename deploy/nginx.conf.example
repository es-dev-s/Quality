# Example nginx reverse proxy for production (HTTPS).
# Replace audit.yourcompany.com and upstream port as needed.
#
# On the server .env:
#   APP_URL="https://audit.yourcompany.com"
#   AUTH_TRUST_HOST="true"
#   ALLOWED_ORIGINS="audit.yourcompany.com"
#   PORT="4782"
#
# Then: npm run build && npm run start

server {
    listen 80;
    server_name audit.yourcompany.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name audit.yourcompany.com;

    # ssl_certificate /etc/letsencrypt/live/audit.yourcompany.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/audit.yourcompany.com/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:4782;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
